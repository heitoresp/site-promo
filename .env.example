# ============================================================
# SUPABASE
# Copie do painel: https://supabase.com/dashboard/project/<id>/settings/api
# ============================================================

# URL pública do projeto
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co

# Chave anônima (segura pra expor no browser — respeita RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave de serviço (NUNCA exponha no browser — bypassa RLS)
# Usada apenas nas API routes server-side
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# API SECRET
# Token Bearer que o bot WhatsApp vai usar no header Authorization
# Gere um: openssl rand -base64 32
# ============================================================
API_SECRET=troque-por-um-token-seguro-gerado-com-openssl

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ApenasPromo
